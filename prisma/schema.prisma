generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/* ======================
   AUTH (НЕ ТРОГАЄМО)
====================== */

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  password    String

  accounts      Account[]
  sessions      Session[]

  // 🔥 NEW: profile data (додаємо, не ламаючи)
  firstName   String?
  lastName    String?
  phone       String?
  age         Int?
  photo       String?

  address     Address?

  cart        Cart?

  orders      Order[]
  favorites   Favorite[]
  views       ViewedProduct[]
  reviews     Review[]

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")

  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/* ======================
   ADDRESS (NEW)
====================== */

model Address {
  id        String @id @default(uuid())

  userId    String @unique
  user      User   @relation(fields: [userId], references: [id])

  region    String
  district  String?
  city      String
  village   String?

  street    String
  house     String
  apartment String?

  postalOffice String?

  createdAt DateTime @default(now())
}

/* ======================
   PRODUCT (ОСНОВНЕ РОЗШИРЕННЯ)
====================== */

model Product {
  id        Int     @id @default(autoincrement())

  title     String
  brand     String
  model     String

  
  // ✅ ДОДАНО ТУТ
  description String  // 🔥 NEW (розширений опис 4–7 речень)

  price     Int
  oldPrice  Int?
  rating    Int     @default(0)

  availability Boolean @default(true)
  discount     Boolean @default(false)

  // 🔥 NEW (9 images)
  images    String[]

  // 🔥 NEW (22+ specs)
  characteristics Json

  // --- OLD FIELDS (залишаємо сумісність)
  image     String?

  type         String
  screenSize   String
  resolution   String
  screenType   String
  refreshRate  Int

  cpu          String
  cores        Int

  gpuBrand     String
  gpuType      String
  gpuModel     String
  vram         Int

  ram          Int
  ramType      String

  ssd          Int
  os           String

  coating      String
  matrixType   String
  batteryType  String

  features     String

  // relations
  reviews     Review[]
  views       ViewedProduct[]
  favorites   Favorite[]
  cartItems   CartItem[]
  orderItems  OrderItem[]

  createdAt DateTime @default(now())
}

/* ======================
   CART (NEW)
====================== */

model Cart {
  id        String @id @default(uuid())

  userId    String @unique
  user      User   @relation(fields: [userId], references: [id])

  items     CartItem[]
}

model CartItem {
  id        String @id @default(uuid())

  cartId    String
  cart      Cart   @relation(fields: [cartId], references: [id])

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  quantity  Int @default(1)
}

/* ======================
   ORDERS
====================== */

model Order {
  id        String @id @default(uuid())

  userId    String
  user      User   @relation(fields: [userId], references: [id])

  total     Int
  status    String @default("pending")

  items     OrderItem[]

  createdAt DateTime @default(now())
}

model OrderItem {
  id        String @id @default(uuid())

  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  quantity  Int
  price     Int
}

/* ======================
   FAVORITES
====================== */

model Favorite {
  id        String @id @default(uuid())

  userId    String
  user      User   @relation(fields: [userId], references: [id])

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
}

/* ======================
   VIEWS
====================== */

model ViewedProduct {
  id        String @id @default(uuid())

  userId    String
  user      User   @relation(fields: [userId], references: [id])

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
}

/* ======================
   REVIEWS
====================== */

model Review {
  id        String @id @default(uuid())

  userId    String
  user      User   @relation(fields: [userId], references: [id])

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  rating    Int
  comment   String

  createdAt DateTime @default(now())
}

/* ======================
   RECIPES (НЕ ТРОГАЄМО)
====================== */

model Ingredient {
  id            String   @id @default(uuid())
  name          String
  category      Category
  unit          Unit
  pricePerUnit  Float?
  description   String?
  recipes       RecipeIngredient[]
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("ingredients")
}

enum Category {
  VEGETABLES
  FRUITS
  MEAT
  DAIRY
  SPICES
  OTHER
}

enum Unit {
  GRAMS
  KILOGRAMS
  LITERS
  MILLILITERS
  PIECES
}

model Recipe {
  id          String   @id @default(uuid())
  name        String
  description String
  imageUrl    String?
  ingredients RecipeIngredient[]

  @@map("recipes")
}

model RecipeIngredient {
  id           String @id @default(uuid())
  recipe       Recipe @relation(fields: [recipeId], references: [id])
  recipeId     String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  ingredientId String
  quantity     Float

  @@map("recipe_ingredient")
}